---
const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname;
function isActive(href: string) {
  if (href === base) return path === base || path === base.replace(/\/$/, '');
  return path.startsWith(href);
}
---

<nav class="site-nav">
  <div class="nav-inner">
    <a class="brand" href={base}>AFTER<span>·</span>HOURS</a>
    <ul class="nav-links">
      <li><a href={`${base}shows`} aria-current={isActive(`${base}shows`) ? 'page' : undefined}>Shows</a></li>
      <li><a href={`${base}about`} aria-current={isActive(`${base}about`) ? 'page' : undefined}>About</a></li>
    </ul>
  </div>
</nav>
