---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';

const base = import.meta.env.BASE_URL;

const allEvents = (await getCollection('events')).sort(
  (a, b) => new Date(a.data.date).valueOf() - new Date(b.data.date).valueOf()
);
const featured = allEvents.slice(0, 3);
---

<BaseLayout
  title="Local concerts, curated weekly"
  description="After Hours — a curated weekly listing of live shows in rooms under 1,000 cap. Indie rock, electronic, jazz, hip-hop, folk."
>
  <header class="hero">
    <div class="hero-img" style="background-image:url('https://images.unsplash.com/photo-1470229722913-7c0e2dbbafd3?w=1800&q=80')"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-eyebrow">Local · Independent · Live</div>
      <h1 class="hero-title">Shows that<br />actually matter</h1>
      <p class="hero-sub">Local concerts, DJ nights, jazz sessions, and album release shows — curated weekly from rooms that hold under a thousand people.</p>
      <div style="margin-top:2rem;display:flex;gap:0.75rem;flex-wrap:wrap">
        <a class="btn btn-primary" href={`${base}shows`}>See All Shows</a>
        <a class="btn btn-ghost" href={`${base}about`}>What is this?</a>
      </div>
    </div>
  </header>

  <section class="section">
    <div class="section-header">
      <div class="section-eyebrow">Up Next</div>
      <h2 class="section-title">Three on the calendar</h2>
      <p class="section-desc">The next three shows. Full listing is on the Shows page.</p>
    </div>

    <div class="card-grid">
      {featured.map((event) => (
        <EventCard
          title={event.data.title}
          date={event.data.date}
          doors={event.data.doors}
          venue={event.data.venue}
          genre={event.data.genre}
          price={event.data.price}
          image={event.data.image}
          href={`${base}events/${event.id}`}
        />
      ))}
    </div>
  </section>
</BaseLayout>
