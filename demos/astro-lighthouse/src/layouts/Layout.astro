---
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <title>{title}</title>
  </head>
  <body>
    <header class="header">
      <div class="header-inner">
        <a href={`${import.meta.env.BASE_URL}`} class="logo">
          <span class="logo-icon" role="img" aria-label="fork and knife">&#127860;</span>
          <span class="logo-text">Quick Bites</span>
        </a>
        <nav class="nav">
          <a href={`${import.meta.env.BASE_URL}`} class="nav-link">Home</a>
          <span class="nav-badge">Astro Static</span>
        </nav>
      </div>
    </header>

    <main class="main">
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <p class="footer-brand">Quick Bites</p>
        <p class="footer-meta">Astro Static Demo &mdash; Applied AI Mastery Curriculum</p>
        <p class="footer-tech">Built with Astro (zero JS shipped to browser)</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Open Sans', system-ui, -apple-system, sans-serif;
    background: #FFFFFF;
    color: #212529;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: 'Nunito', system-ui, sans-serif;
    font-weight: 700;
    line-height: 1.3;
  }

  a {
    color: #6366F1;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  img {
    max-width: 100%;
    display: block;
  }

  .header {
    background: #FFFFFF;
    border-bottom: 1px solid #E5E7EB;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: #212529;
  }

  .logo:hover { text-decoration: none; }

  .logo-icon { font-size: 1.5rem; }

  .logo-text {
    font-family: 'Nunito', system-ui, sans-serif;
    font-weight: 800;
    font-size: 1.4rem;
    color: #6366F1;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-link {
    font-weight: 500;
    color: #212529;
    padding: 0.4rem 0.8rem;
    border-radius: 0.5rem;
    transition: background 0.15s;
  }

  .nav-link:hover {
    background: #F8F9FA;
    text-decoration: none;
  }

  .nav-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: #FEF3C7;
    color: #D97706;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    font-family: 'Nunito', system-ui, sans-serif;
  }

  .main {
    flex: 1;
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  .footer {
    background: #F8F9FA;
    border-top: 1px solid #E5E7EB;
    padding: 2rem 1.5rem;
    margin-top: auto;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }

  .footer-brand {
    font-family: 'Nunito', system-ui, sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: #6366F1;
    margin-bottom: 0.25rem;
  }

  .footer-meta {
    font-size: 0.85rem;
    color: #6B7280;
  }

  .footer-tech {
    font-size: 0.75rem;
    color: #9CA3AF;
    margin-top: 0.5rem;
  }
</style>
