---
import Layout from '../../layouts/Layout.astro';
import { recipes } from '../../data/recipes.js';

export function getStaticPaths() {
  return recipes.map((recipe) => ({
    params: { id: String(recipe.id) },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
---
<Layout title={`${recipe.title} — Quick Bites`}>
  <article class="recipe-page">
    <a href={`${import.meta.env.BASE_URL}`} class="back-link">&larr; All recipes</a>

    <div class="recipe-hero">
      <img src={recipe.image} alt={recipe.title} class="recipe-hero-image" width="760" height="320" />
      <div class="recipe-hero-overlay">
        <span class="recipe-category-badge">{recipe.category}</span>
        <h1 class="recipe-title">{recipe.title}</h1>
      </div>
    </div>

    <div class="recipe-meta-bar">
      <div class="meta-chip">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12,6 12,12 16,14"/>
        </svg>
        {recipe.time}
      </div>
      <div class="meta-chip">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
        </svg>
        {recipe.servings} servings
      </div>
      <div class={`meta-chip difficulty-chip difficulty-${recipe.difficulty.toLowerCase()}`}>
        {recipe.difficulty}
      </div>
    </div>

    <p class="recipe-description">{recipe.description}</p>

    <div class="recipe-content">
      <section class="recipe-section">
        <h2>Ingredients</h2>
        <ul class="ingredients-list">
          {recipe.ingredients.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      <section class="recipe-section">
        <h2>Instructions</h2>
        <ol class="steps-list">
          {recipe.steps.map((step, i) => (
            <li>
              <span class="step-number">{i + 1}</span>
              <span class="step-text">{step}</span>
            </li>
          ))}
        </ol>
      </section>
    </div>
  </article>
</Layout>

<style>
  .recipe-page {
    max-width: 760px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: #6366F1;
    margin-bottom: 1.5rem;
  }

  .recipe-hero {
    position: relative;
    border-radius: 0.5rem;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .recipe-hero-image {
    width: 100%;
    height: 320px;
    object-fit: cover;
  }

  .recipe-hero-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem 1.5rem 1.5rem;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  }

  .recipe-category-badge {
    display: inline-block;
    background: #6366F1;
    color: #FFFFFF;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.5rem;
  }

  .recipe-title {
    font-size: 1.75rem;
    color: #FFFFFF;
    font-weight: 800;
  }

  .recipe-meta-bar {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .meta-chip {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.8rem;
    background: #F8F9FA;
    border: 1px solid #E5E7EB;
    border-radius: 9999px;
    font-size: 0.8rem;
    color: #6B7280;
  }

  .difficulty-chip.difficulty-easy {
    background: #ECFDF5;
    border-color: #A7F3D0;
    color: #059669;
  }

  .difficulty-chip.difficulty-medium {
    background: #FFF7ED;
    border-color: #FED7AA;
    color: #D97706;
  }

  .difficulty-chip.difficulty-hard {
    background: #FEF2F2;
    border-color: #FECACA;
    color: #DC2626;
  }

  .recipe-description {
    font-size: 1.05rem;
    color: #4B5563;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .recipe-content {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 2rem;
  }

  .recipe-section h2 {
    font-size: 1.2rem;
    font-weight: 700;
    color: #212529;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #6366F1;
  }

  .ingredients-list {
    list-style: none;
    padding: 0;
  }

  .ingredients-list li {
    padding: 0.5rem 0;
    border-bottom: 1px solid #F3F4F6;
    font-size: 0.9rem;
    color: #374151;
  }

  .ingredients-list li:last-child {
    border-bottom: none;
  }

  .steps-list {
    list-style: none;
    padding: 0;
  }

  .steps-list li {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
    align-items: flex-start;
  }

  .step-number {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    background: #6366F1;
    color: #FFFFFF;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
    font-family: 'Nunito', system-ui, sans-serif;
  }

  .step-text {
    font-size: 0.9rem;
    color: #374151;
    line-height: 1.6;
    padding-top: 0.15rem;
  }

  @media (max-width: 640px) {
    .recipe-hero-image {
      height: 220px;
    }
    .recipe-title {
      font-size: 1.4rem;
    }
    .recipe-content {
      grid-template-columns: 1fr;
    }
  }
</style>
