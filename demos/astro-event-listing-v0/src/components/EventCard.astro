---
interface Props {
  title: string;
  date: string;      // ISO date, e.g. '2026-03-14'
  doors: string;     // 'Fri 8 PM'
  venue: string;
  genre: string;
  price: string;
  image: string;
  href?: string;
}

const { title, date, doors, venue, genre, price, image, href = '#' } = Astro.props;

const d = new Date(date);
const day = d.getUTCDate().toString().padStart(2, '0');
const month = d.toLocaleString('en-US', { month: 'short', timeZone: 'UTC' });
---

<a class="event-card" href={href}>
  <div class="event-card-img" style={`background-image:url('${image}')`}>
    <div class="date-chip">
      <span class="date-chip-day">{day}</span>
      <span class="date-chip-month">{month}</span>
    </div>
  </div>
  <div class="event-card-body">
    <div class="event-card-meta">{doors} · {venue}</div>
    <h3 class="event-card-title">{title}</h3>
    <div class="event-card-bottom">
      <span class="pill">{genre}</span>
      <span class="event-card-price">{price}</span>
    </div>
  </div>
</a>
