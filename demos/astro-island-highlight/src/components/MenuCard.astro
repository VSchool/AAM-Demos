---
import type { MenuItem } from '../data/menu';

interface Props {
  item: MenuItem;
}

const { item } = Astro.props;

const priceFormatted = item.price % 1 === 0
  ? `$${item.price}`
  : `$${item.price.toFixed(2)}`;

const categoryLabel = item.category.charAt(0).toUpperCase() + item.category.slice(1);
---

<li
  class="menu-card"
  data-menu-id={item.id}
  data-menu-name={item.name.toLowerCase()}
  data-menu-description={item.description.toLowerCase()}
  data-menu-category={item.category}
>
  <div class="menu-card__header">
    <h3 class="menu-card__name">{item.name}</h3>
    <span class="menu-card__price">{priceFormatted}</span>
  </div>
  <p class="menu-card__description">{item.description}</p>
  <div class="menu-card__footer">
    <span class="menu-card__category">{categoryLabel}</span>
    {item.tag && <span class="menu-card__tag">{item.tag}</span>}
  </div>
</li>
