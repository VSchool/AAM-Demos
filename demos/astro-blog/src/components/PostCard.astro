---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  slug: string;
}

const { title, description, pubDate, tags, slug } = Astro.props;
const base = import.meta.env.BASE_URL;

const dateStr = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="post-card">
  <a href={`${base}blog/${slug}/`} class="post-link">
    <time class="post-date" datetime={pubDate.toISOString()}>{dateStr}</time>
    <h3 class="post-title">{title}</h3>
    <p class="post-description">{description}</p>
    <div class="post-tags">
      {tags.map(tag => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  </a>
</article>

<style>
  .post-card {
    border: 1px solid #21262D;
    border-radius: 0.375rem;
    transition: border-color 0.15s ease;
  }

  .post-card:hover {
    border-color: #30363D;
  }

  .post-link {
    display: block;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
  }

  .post-date {
    display: block;
    color: #8B949E;
    font-size: 0.8125rem;
    font-family: 'JetBrains Mono', monospace;
    margin-bottom: 0.5rem;
  }

  .post-title {
    color: #E6EDF3;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .post-card:hover .post-title {
    color: #58A6FF;
  }

  .post-description {
    color: #8B949E;
    font-size: 0.9375rem;
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }

  .post-tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .tag {
    background: #21262D;
    color: #8B949E;
    font-size: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    padding: 0.125rem 0.5rem;
    border-radius: 0.25rem;
  }
</style>
