---
interface Props {
  type?: 'info' | 'warning' | 'tip';
}

const { type = 'info' } = Astro.props;

const icons: Record<string, string> = {
  info: 'i',
  warning: '!',
  tip: '*',
};

const labels: Record<string, string> = {
  info: 'Note',
  warning: 'Warning',
  tip: 'Tip',
};
---

<aside class={`callout callout-${type}`} role="note">
  <span class="callout-icon">{icons[type]}</span>
  <div class="callout-content">
    <strong class="callout-label">{labels[type]}</strong>
    <slot />
  </div>
</aside>

<style>
  .callout {
    display: flex;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-radius: 0.375rem;
    border-left: 3px solid;
    margin: 1.5rem 0;
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .callout-icon {
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-weight: 700;
    font-size: 0.8125rem;
  }

  .callout-content {
    flex: 1;
  }

  .callout-label {
    display: block;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  .callout-info {
    background: rgba(88, 166, 255, 0.08);
    border-color: #58A6FF;
  }
  .callout-info .callout-icon {
    background: rgba(88, 166, 255, 0.15);
    color: #58A6FF;
  }
  .callout-info .callout-label {
    color: #58A6FF;
  }

  .callout-warning {
    background: rgba(247, 129, 102, 0.08);
    border-color: #F78166;
  }
  .callout-warning .callout-icon {
    background: rgba(247, 129, 102, 0.15);
    color: #F78166;
  }
  .callout-warning .callout-label {
    color: #F78166;
  }

  .callout-tip {
    background: rgba(63, 185, 80, 0.08);
    border-color: #3FB950;
  }
  .callout-tip .callout-icon {
    background: rgba(63, 185, 80, 0.15);
    color: #3FB950;
  }
  .callout-tip .callout-label {
    color: #3FB950;
  }
</style>
