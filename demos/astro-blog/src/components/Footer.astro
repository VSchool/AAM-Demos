---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <p class="footer-text">
      &copy; {year} Kai Chen &middot; Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
    </p>
    <p class="footer-meta">Zero JavaScript shipped on this page.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid #21262D;
    padding: 2rem 1.5rem;
    margin-top: auto;
  }

  .footer-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .footer-text {
    color: #8B949E;
    font-size: 0.8125rem;
  }

  .footer-text a {
    color: #58A6FF;
    text-decoration: none;
  }

  .footer-text a:hover {
    text-decoration: underline;
  }

  .footer-meta {
    color: #484F58;
    font-size: 0.75rem;
    margin-top: 0.375rem;
    font-family: 'JetBrains Mono', monospace;
  }
</style>
