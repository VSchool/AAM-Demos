---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Dev Notes by Kai Chen — a blog about building software.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Dev Notes</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>

<style is:global>
  /* ========== Reset ========== */
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  /* ========== Base ========== */
  html {
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    background: #0D1117;
    color: #E6EDF3;
    font-family: 'IBM Plex Sans', system-ui, -apple-system, sans-serif;
    line-height: 1.7;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
    width: 100%;
    max-width: 720px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem;
  }

  /* ========== Typography ========== */
  h1, h2, h3, h4 {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    color: #E6EDF3;
    line-height: 1.3;
    font-weight: 600;
  }

  h1 { font-size: 2rem; margin-bottom: 1rem; }
  h2 { font-size: 1.5rem; margin-top: 2.5rem; margin-bottom: 0.75rem; }
  h3 { font-size: 1.1875rem; margin-top: 2rem; margin-bottom: 0.5rem; }

  p {
    margin-bottom: 1.25rem;
    color: #C9D1D9;
  }

  strong {
    color: #E6EDF3;
    font-weight: 600;
  }

  a {
    color: #58A6FF;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  /* ========== Lists ========== */
  ul, ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    color: #C9D1D9;
  }

  li {
    margin-bottom: 0.375rem;
  }

  li strong {
    color: #E6EDF3;
  }

  /* ========== Code ========== */
  code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.875em;
    background: #161B22;
    color: #E6EDF3;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    border: 1px solid #21262D;
  }

  pre {
    background: #161B22;
    border: 1px solid #21262D;
    border-radius: 0.375rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    line-height: 1.5;
  }

  pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.8125rem;
    color: #E6EDF3;
  }

  /* ========== Blockquote ========== */
  blockquote {
    border-left: 3px solid #30363D;
    padding-left: 1rem;
    color: #8B949E;
    margin-bottom: 1.25rem;
    font-style: italic;
  }

  /* ========== HR ========== */
  hr {
    border: none;
    border-top: 1px solid #21262D;
    margin: 2rem 0;
  }

  /* ========== Images ========== */
  img {
    max-width: 100%;
    height: auto;
    border-radius: 0.375rem;
  }
</style>
