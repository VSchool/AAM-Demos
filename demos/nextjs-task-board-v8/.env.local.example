# ── V8 environment variables (shape reference — placeholders only) ──
# Copy to .env.local and fill in real values. .env.local is gitignored.
# In production, set these in the Vercel project's Environment Variables.

# MongoDB connection string.
#   Local dev:  mongodb://127.0.0.1:27017/cadence-v8
#   Production: MongoDB Atlas SRV string (Connect → Drivers)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/cadence-v8

# Secret used to sign/verify JWTs. Mint with: openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-string

# OpenWeatherMap "Current Weather Data" free tier API key (server-side only —
# never exposed to the browser). https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweathermap-key

# Seed account used to demonstrate cross-device persistence.
SEED_USER_EMAIL=demo@cadence.app
SEED_USER_PASSWORD=change-me
