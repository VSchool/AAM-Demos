---
interface Props {
  heading: string;
  tagline: string;
  imageSrc?: string;
  imageAlt?: string;
}

const { heading, tagline, imageSrc, imageAlt = '' } = Astro.props;
---

<section class="page-hero">
  {imageSrc && (
    <div class="hero-image-wrap">
      <img src={imageSrc} alt={imageAlt} class="hero-image" loading="eager" />
      <div class="hero-overlay"></div>
    </div>
  )}
  <div class="hero-content" class:list={[{ 'has-image': !!imageSrc }]}>
    <h1>{heading}</h1>
    <p>{tagline}</p>
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
  }

  .hero-image-wrap {
    position: relative;
    width: 100%;
    max-height: 420px;
    overflow: hidden;
  }

  .hero-image {
    width: 100%;
    height: 420px;
    object-fit: cover;
    object-position: center 30%;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(247, 245, 240, 0) 0%,
      rgba(247, 245, 240, 0.6) 70%,
      rgba(247, 245, 240, 1) 100%
    );
  }

  .hero-content {
    text-align: center;
    padding: 4rem 1.5rem 2rem;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .hero-content.has-image {
    margin-top: -6rem;
    position: relative;
    z-index: 1;
    padding-top: 0;
  }

  h1 {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.15;
    margin-bottom: 0.75rem;
  }

  p {
    font-size: 1.1rem;
    color: var(--color-muted);
    max-width: 540px;
    margin: 0 auto;
    line-height: 1.6;
  }
</style>
