---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ValueBlock from '../components/ValueBlock.astro';
---

<BaseLayout title="Home" description="Still Point Yoga — a calm, welcoming studio for every body and every level.">
  <PageHero
    heading="Still Point Yoga"
    tagline="Where movement meets stillness. Classes for every body, every level, every day."
    imageSrc="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=1200&q=80"
    imageAlt="Yoga practice in a sunlit studio"
  />

  <section class="values-section">
    <div class="values-inner">
      <h2>Why Still Point</h2>
      <div class="values-grid">
        <ValueBlock
          icon="🌿"
          heading="All Levels Welcome"
          text="From your very first downward dog to advanced inversions, our teachers meet you exactly where you are."
        />
        <ValueBlock
          icon="🔥"
          heading="Build Real Strength"
          text="Yoga is not just stretching. Our power and vinyasa classes build functional strength you carry off the mat."
        />
        <ValueBlock
          icon="🧘"
          heading="Find Your Calm"
          text="Restorative and yin classes give your nervous system the reset it needs. Slow down without checking out."
        />
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="cta-inner">
      <h2>Ready to begin?</h2>
      <p>Browse our class schedule and find the practice that fits your life.</p>
      <a href={`${import.meta.env.BASE_URL}classes/`} class="cta-link">View Classes</a>
    </div>
  </section>
</BaseLayout>

<style>
  .values-section {
    padding: 3rem 1.5rem 2rem;
  }

  .values-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
  }

  .values-inner h2 {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 2.5rem;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
  }

  .cta-section {
    padding: 3rem 1.5rem 4rem;
    text-align: center;
  }

  .cta-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    background: var(--color-card);
    border-radius: var(--radius);
    padding: 3rem 2rem;
    box-shadow: 0 1px 3px rgba(26, 26, 46, 0.06);
  }

  .cta-inner h2 {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .cta-inner p {
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .cta-link {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: var(--color-accent);
    color: #fff;
    border-radius: 9999px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: background 0.2s ease, transform 0.15s ease;
  }

  .cta-link:hover {
    background: #6a5c7a;
    color: #fff;
    transform: translateY(-1px);
  }
</style>
