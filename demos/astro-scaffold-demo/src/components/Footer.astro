---
// Footer component — shared across all pages
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <p class="footer-brand">Rise &amp; Grain</p>
    <p class="footer-tagline">Hand-shaped sourdough since 2018</p>
    <p class="footer-copy">&copy; {year} Rise &amp; Grain Bakery. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--text);
    color: var(--bg);
    margin-top: 5rem;
    padding: 3rem 1.5rem;
    text-align: center;
  }

  .footer-inner {
    max-width: 820px;
    margin: 0 auto;
  }

  .footer-brand {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--bg);
    margin-bottom: 0.25rem;
  }

  .footer-tagline {
    font-size: 0.9rem;
    color: rgba(253, 248, 240, 0.6);
    font-style: italic;
    margin-bottom: 1rem;
  }

  .footer-copy {
    font-size: 0.8rem;
    color: rgba(253, 248, 240, 0.4);
  }
</style>
