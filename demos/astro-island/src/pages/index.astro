---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostSearch from '../components/PostSearch.jsx';

const allPosts = await getCollection('blog');

// Sort newest first
const sortedPosts = allPosts.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

// Simplify for the React island — only serializable data
const simplifiedPosts = sortedPosts.map((post) => ({
  slug: post.id,
  title: post.data.title,
  description: post.data.description,
  tags: post.data.tags,
  image: post.data.image,
}));
---

<BaseLayout title="Home">
  <section class="hero">
    <img
      class="hero-bg"
      src="https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=1200&q=80"
      alt=""
    />
    <div class="hero-content">
      <h1>Salt &amp; Pixel</h1>
      <p>Recipes, stories, and the science behind the flavor</p>
    </div>
  </section>

  <section class="island-section">
    <div style="text-align: center;">
      <span class="island-label">React Island &mdash; client:load</span>
    </div>
    <PostSearch posts={simplifiedPosts} basePath={import.meta.env.BASE_URL} client:load />
  </section>
</BaseLayout>
